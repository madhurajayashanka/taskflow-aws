# ═══════════════════════════════════════════════════════════════════
# TaskFlow — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file:  cp .env.example .env
# Then fill in the values below. Never commit the .env file.
# ═══════════════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string

# Options: app.settings.development | app.settings.production
DJANGO_SETTINGS_MODULE=app.settings.development

# Comma-separated list of allowed hosts (production: your domain/IP)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=taskflow_db
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Full database URL (used by Django via dj-database-url)
DATABASE_URL=postgres://taskflow_user:change-me-to-a-strong-password@db:5432/taskflow_db

# ── AWS / S3 (optional for local dev, required for production) ─────
# On EC2, credentials come from the IAM Instance Profile automatically.
# For local dev with S3, set these (or leave blank to use local file storage).
AWS_S3_BUCKET_NAME=
AWS_REGION=us-east-1

# ── Frontend ────────────────────────────────────────────────────────
# Base URL for API calls from the React app
VITE_API_URL=http://localhost
